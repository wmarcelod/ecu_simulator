  "physical_rules": {
    "engine_off": {
      "condition": "rpm == 0",
      "constraints": {
        "speed": 0,
        "engine_load": 0,
        "maf": 0,
        "throttle": 0,
        "map_kpa": 101,
        "voltage": {
          "min": 11.8,
          "max": 12.8
        }
      }
    },
    "idle": {
      "condition": "rpm in [600, 900] and speed < 5",
      "constraints": {
        "rpm": {
          "min": 600,
          "max": 900
        },
        "speed": {
          "min": 0,
          "max": 5
        },
        "engine_load": {
          "min": 10,
          "max": 30
        },
        "throttle": {
          "min": 0,
          "max": 7
        },
        "maf": {
          "min": 1.5,
          "max": 6.0
        },
        "map_kpa": {
          "min": 25,
          "max": 50
        },
        "voltage": {
          "min": 13.2,
          "max": 14.8
        }
      }
    },
    "acceleration": {
      "condition": "throttle > 30 and rpm increasing",
      "constraints": {
        "engine_load": {
          "min": 40,
          "max": 100
        },
        "maf": {
          "min": 10,
          "max": 100
        },
        "map_kpa": {
          "min": 50,
          "max": 105
        }
      }
    },
    "cruise": {
      "condition": "speed stable, throttle stable",
      "constraints": {
        "engine_load": {
          "min": 15,
          "max": 45
        },
        "throttle": {
          "min": 10,
          "max": 30
        },
        "maf": {
          "min": 5,
          "max": 25
        }
      }
    },
    "deceleration": {
      "condition": "throttle == 0, speed decreasing",
      "constraints": {
        "throttle": {
          "min": 0,
          "max": 2
        },
        "engine_load": {
          "min": 0,
          "max": 15
        },
        "maf": {
          "min": 0.5,
          "max": 4
        },
        "map_kpa": {
          "min": 20,
          "max": 40
        }
      }
    },
    "thermal_model": {
      "coolant_warmup_rate_degC_per_sec": 0.05,
      "coolant_target_temp": 90,
      "coolant_thermostat_threshold": 85,
      "coolant_overheat_threshold": 105,
      "oil_temp_follows_coolant_delay_sec": 40,
      "oil_temp_offset_under_load": 10,
      "iat_above_ambient_idle": 3,
      "iat_above_ambient_load": 10
    },
