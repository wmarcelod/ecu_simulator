    given-names: "Marcelo"
    affiliation: "Instituto de Ciências Matemáticas e de Computação, Universidade de São Paulo (ICMC/USP)"
  - family-names: "Branco"
    given-names: "Kalinka Regina Lucas Jaquie Castelo"
    affiliation: "ICMC/USP"
